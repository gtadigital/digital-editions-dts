	<text>
		<body>
			<pb facs="#facs_1" n="1" xml:id="F20_Ms_185_1r"/>
			<p facs="#facs_1_r1" xml:id="p.ttwfhi"><handShift new="#hGS" script="Kurrent" medium="STinte"/>
				<lb facs="#facs_1_r1l1" n="N001"/><handShift new="#hWH" medium="Blei" script="Latein"/><hi rend="Kreis">1</hi>
			</p>
			<p facs="#facs_1_r2" xml:id="p.Dh7YVJ">
				<lb facs="#facs_1_r2l1" n="N001"/><handShift new="#hGS" medium="STinte" script="Kurrent"/>000<unclear>.</unclear>
			</p>
			<p facs="#facs_1_r3" xml:id="p.OXGXd9" next="#p.AhvXoy">
				<lb facs="#facs_1_r3l1" n="N001"/>Naturereignisse trieb sie aus den
				<lb facs="#facs_1_r3l2" n="N002"/>Ursitzen. Dieselben trieb sie
				<lb facs="#facs_1_r3l3" n="N003"/>auch wieder <del rend="durchstr STinte" xml:id="del.YnV9Pv">b<unclear>eis</unclear></del> zusammen
				<lb facs="#facs_1_r3l4" n="N004"/>Chin<unclear><subst><del rend="überschr" xml:id="del.GMZUIn">a</del><add xml:id="add.GzatWd">e</add></subst></unclear>sische Sündfluth.
			</p>
			<p facs="#facs_1_r4" xml:id="p.AhvXoy" prev="#p.OXGXd9" next="#p.Vv8s3J">
				<lb facs="#facs_1_r4l1" n="N001"/>Die Hegerssöhne <unclear reason="capitalized or not">n</unclear>at<sic>u</sic>rliche Feinde
				<lb facs="#facs_1_r4l2" n="N002"/>d<unclear>er</unclear> <sic>Civi<subst><del>l</del><add>s</add></subst>ation</sic>, ihrer nicht unkundig
				<lb facs="#facs_1_r4l3" n="N003"/><sic>sonder</sic> <subst><del xml:id="del.HovMy5">a</del><add xml:id="add.ZcrETy">A</add></subst><unclear>usgestossene</unclear> – Krieg
				<lb facs="#facs_1_r4l4" n="N004"/>Eroberung – Neue Formen
				<lb facs="#facs_1_r4l5" n="N005"/>auf die alten geimpft.
			</p>
			<p facs="#facs_1_r5" xml:id="p.Vv8s3J" prev="#p.AhvXoy" next="#p.szEQUk">
				<lb facs="#facs_1_r5l1" n="N001"/>Gegensätze die sich hie<unclear>r</unclear>bei kund ge<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_1_r5l2" n="N002" type="hyph"/>ben und formell gestalten. –
			</p>
			<p facs="#facs_1_r6" xml:id="p.szEQUk" prev="#p.Vv8s3J" next="#p.2W2tYk">
				<lb facs="#facs_1_r6l1" n="N001"/><hi rend="unterstr">Autoritätstrieb</hi> <hi rend="unterstr">Freiheitstrieb</hi>.
				<lb facs="#facs_1_r6l2" n="N002"/>Autorität in allen <del rend="durchstr STinte" xml:id="del.VDcuVN"><unclear><sic>a</sic>lte<unclear>st</unclear>e</unclear></del> sekundär
				<lb facs="#facs_1_r6l3" n="N003"/><unclear>gestllige</unclear> Formen die Herrschende.
				<lb facs="#facs_1_r6l4" n="N004"/>Zeigt sich in doppelter Form.
			</p>
			<p facs="#facs_1_r7" xml:id="p.2W2tYk" prev="#p.szEQUk" next="#p.IkLOCW">
				<lb facs="#facs_1_r7l1" n="N001"/>1<hi rend="hoch">o</hi>) Herrschaft des <hi rend="unterstr STinte">Urstammes</hi>, Stammes-
				<lb facs="#facs_1_r7l2" n="N002" type="hyph"/><del rend="durchstr STinte" xml:id="del.legHHf">herrschaft</del> Autorität, Autochtonen<add place="in_Zeile" xml:id="add.VK8N35">herrschaft</add>
				<lb facs="#facs_1_r7l3" n="N003"/>Priestergewalt, Erbadel. <unclear><rs type="place" ref="ortsregister.xml#EGYPT1">Aegypten</rs></unclear>.
				<lb facs="#facs_1_r7l4" n="N004"/>Oft nimmt die siegend<unclear>e</unclear> erobernde
				<lb facs="#facs_1_r7l5" n="N005"/>Parthei diese Autorit<sic>a</sic>tsform als
				<lb facs="#facs_1_r7l6" n="N006"/>fremdes <rs type="artefact" ref="artefaktenregister.xml#THING0258">Gewand</rs> über. <rs type="place" ref="ortsregister.xml#INDIEN1">Indien</rs>.
				<lb facs="#facs_1_r7l7" n="N007"/><unclear>selbst</unclear> <rs type="place" ref="ortsregister.xml#EGYPT1">Aegypten</rs>. Vergl. des Christen-
				<lb facs="#facs_1_r7l8" n="N008" type="hyph"/>thum mit de<unclear>m</unclear> Aegyptischen.
			</p>
			<p facs="#facs_1_r8" xml:id="p.IkLOCW" prev="#p.2W2tYk" next="#p.ULVjTy">
				<lb facs="#facs_1_r8l1" n="N001"/>2<hi rend="hoch">o</hi>) <hi rend="unterstr STinte">Herrschaft des Eroberers</hi>.
				<lb facs="#facs_1_r8l2" n="N002"/>Militärische <rs type="term" ref="begriffsregister.xml#TERM0408">Form</rs> der Gesellschaft
				<lb facs="#facs_1_r8l3" n="N003"/>Lehnsadel. Die Religion im
				<lb facs="#facs_1_r8l4" n="N004"/>Dienste der weltlichen Macht
				<lb facs="#facs_1_r8l5" n="N005"/><add place="vor_Zeile" xml:id="add.QsdFGL">die Gottheit</add> Repräsentantin <del rend="durchstr STinte" xml:id="del.QNdwWO">d</del> und das <unclear extent="5 Graphen" unit="char" quantity="5"/>
				<lb facs="#facs_1_r8l6" n="N006"/>des <subst><del rend="überschr" xml:id="del.kTGCuz">H</del></subst>errschers. <rs type="place" ref="ortsregister.xml#BABYLON1">Babylon</rs>, <rs type="place" ref="ortsregister.xml#ASSYRIEN1">Assyrien</rs>
				<lb facs="#facs_1_r8l7" n="N007"/>Chalifen. Stets in <rs type="place" ref="ortsregister.xml#ASIEN1">Asien</rs>
				<lb facs="#facs_1_r8l8" n="N008"/>herrschendes System. Auch in
				<lb facs="#facs_1_r8l9" n="N009"/><rs type="place" ref="ortsregister.xml#CHINA1">China</rs> - <hi rend="unterstr">Nicht in <rs type="place" ref="ortsregister.xml#INDIEN1">Indien</rs>.</hi>
			</p>
			<p facs="#facs_1_r9" xml:id="p.ULVjTy" prev="#p.IkLOCW" next="#p.OY1oGr">
				<lb facs="#facs_1_r9l1" n="N001"/>Diese beiden gesellschaftliche Gegen<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_1_r9l2" n="N002" type="hyph"/>sätze zeigen sich an de<unclear>r</unclear> Grenze
				<lb facs="#facs_1_r9l3" n="N003"/>der Baugeschichte als in de<unclear>r</unclear>
				<lb facs="#facs_1_r9l4" n="N004"/>Bauliche <rs type="term" ref="begriffsregister.xml#TERM0408">Form</rs> ausgedrückt.
			</p>
			<p facs="#facs_1_r10" xml:id="p.OY1oGr" prev="#p.ULVjTy" next="20_Ms_185_2.xml#p.0MQ3S1">
				<lb facs="#facs_1_r10l1" n="N001"/>Die gestreuten Stämme
				<lb facs="#facs_1_r10l2" n="N002"/><rs type="place" ref="ortsregister.xml#EUROPA1">Europas</rs> Zersplitterungen der-
				<lb facs="#facs_1_r10l3" n="N003" type="hyph"/>artige Urzustände
				<lb facs="#facs_1_r10l4" n="N004"/><rs type="people" ref="voelkerregister.xml#PEOPLE0029">Hellenen</rs> und <rs type="people" ref="voelkerregister.xml#PEOPLE0024">Römer</rs>
				<lb facs="#facs_1_r10l5" n="N005"/><rs type="people" ref="voelkerregister.xml#PEOPLE0094">Italer</rs> <rs type="people" ref="voelkerregister.xml#PEOPLE0013">Italo-Graeci</rs>.
			</p>
			<p facs="#facs_1_r11" xml:id="p.Q88UPz">
				<lb facs="#facs_1_r11l1" n="N001"/>Freiheit des Zusammenwirkens
				<lb facs="#facs_1_r11l2" n="N002"/>vielleicht d<unclear>ie</unclear> älteste <unclear>Form</unclear><unclear><del rend="durchstr">.</del></unclear>
				<lb facs="#facs_1_r11l3" n="N003"/>aber von kurzer Dauer. <del rend="durchstr STinte" xml:id="del.tWWU67">fraglich</del>.
			</p>
			<join target="#p.OY1oGr 20_Ms_185_2.xml#p.46eCQD"/>
		</body>
	</text>
