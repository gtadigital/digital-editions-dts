	<text>
		<body>
			<pb facs="#facs_2" n="2" xml:id="F20_Ms_184_1v"/>
			<p facs="#facs_2_r1" xml:id="p.i9YmrF"><handShift new="#hGS" script="Kurrent" medium="Blei"/>
				<lb facs="#facs_2_r1l1" n="N001"/><handShift new="#hWH"/><hi rend="Kreis">2</hi><handShift new="#hGS"/>
			</p>
			<p facs="#facs_2_r2" xml:id="p.UKOq1E" prev="20_MS_184_1.xml#p.m9j97A" next="#p.DJF4ah">
				<lb facs="#facs_2_r2l1" n="N001"/><handShift script="Latein"/><subst><del rend="überschr">g</del><add>G</add></subst>ewänder - Costum<handShift script="Kurrent"/>geschichte
				<lb facs="#facs_2_r2l2" n="N002"/><handShift script="Latein"/>Waffen. - Hoplonomie
				<lb facs="#facs_2_r2l3" n="N003"/><rs type="artefact" ref="artefaktenregister.xml#THING0260">Teppiche</rs> und -
				<lb facs="#facs_2_r2l4" n="N004"/>Wandbekleidungen -
				<lb facs="#facs_2_r2l5" n="N005"/>Baugeschichte.
			</p>
			<p facs="#facs_2_r3" xml:id="p.DJF4ah" prev="#p.UKOq1E" next="#p.JLDhqw">
				<lb facs="#facs_2_r3l1" n="N001"/><handShift script="Kurrent"/>Wichtiger Einfluss
				<lb facs="#facs_2_r3l2" n="N002"/>d<unclear>er</unclear> Teppichwir<unclear>kerei</unclear>
				<lb facs="#facs_2_r3l3" n="N003"/>auf die Symbolik des
				<lb facs="#facs_2_r3l4" n="N004"/>Alterthums dto des
				<lb facs="#facs_2_r3l5" n="N005"/>Mittelalters.
			</p>
			<p facs="#facs_2_r4" xml:id="p.JLDhqw" prev="#p.DJF4ah" next="#p.6R4WlA">
				<lb facs="#facs_2_r4l1" n="N001"/>Hier sollte eigentlich
				<lb facs="#facs_2_r4l2" n="N002"/>die Geschichte und Kunstlehre 
				<lb facs="#facs_2_r4l3" n="N003"/>der gesammt<unclear>en</unclear> <hi rend="unterstr">bildenden Kunst</hi>
				<lb facs="#facs_2_r4l4" n="N004"/>folgen. <unclear>D</unclear>ie Glasmalerei
				<lb facs="#facs_2_r4l5" n="N005"/>und Mosaikmalerei,
				<lb facs="#facs_2_r4l6" n="N006"/>der Stuckmarmor, <handShift script="Latein"/>Fresco.<metamark rend="Linie" function="Einfügung" target="#p.3BPULy"></metamark><handShift script="Kurrent"/>
			</p>
			<p facs="#facs_2_r5" xml:id="p.6R4WlA" prev="#p.JLDhqw" next="#p.HiI5QN">
				<lb facs="#facs_2_r5l1" n="N001"/>Vielleicht nur
				<lb facs="#facs_2_r5l2" n="N002"/>hier darauf hinzu<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_2_r5l3" n="N003" type="hyph"/>deuten.
				<lb facs="#facs_2_r5l4" n="N004"/>aber doch deutlich mach
				<lb facs="#facs_2_r5l5" n="N005"/>dass d. Begriff Beklei-
				<lb facs="#facs_2_r5l6" n="N006" type="hyph"/>dung Wand weiter geht als
				<lb facs="#facs_2_r5l7" n="N007"/>das <rs type="artefact" ref="artefaktenregister.xml#THING0259">Gewebe</rs>. - 
			</p>
			<p facs="#facs_2_r6" xml:id="p.HiI5QN" prev="#p.6R4WlA" next="#p.bQhxff">
				<lb facs="#facs_2_r6l1" n="N001"/><del rend="durchstr" xml:id="del.sNlplt">Symbole d<unclear>er</unclear> Griechischen</del> Spätere Nachbildung
				<lb facs="#facs_2_r6l2" n="N002"/>der Wandbekleidung<unclear>en</unclear>
				<lb facs="#facs_2_r6l3" n="N003"/><retrace>d</retrace>urch
				<lb facs="#facs_2_r6l4" n="N004"/>a) Stuck
				<lb facs="#facs_2_r6l5" n="N005"/>b) Holz.
				<lb facs="#facs_2_r6l6" n="N006"/>c) Metall &amp; Holz.
				<lb facs="#facs_2_r6l7" n="N007"/>d) Stein.
			</p>
			<p facs="#facs_2_r7" xml:id="p.3BPULy">
				<lb facs="#facs_2_r7l1" n="N001"/><metamark rend="Linie"></metamark><handShift script="Latein"/>Pompei<handShift script="Kurrent"/>
			</p>
			<p facs="#facs_2_r8" xml:id="p.bQhxff" prev="#p.HiI5QN" next="#p.zhAluD">
				<lb facs="#facs_2_r8l1" n="N001"/>Ursprung des <subst><del rend="durchstr" xml:id="del.94jrtw">A<unclear extent="1 Graph" unit="char" quantity="1"></unclear></del><add xml:id="add.dJvfRf">Qu</add></subst>aderwerks.
				<lb facs="#facs_2_r8l2" n="N002"/>Assyrer, Perser, Aegypter<unclear>.</unclear>
				<lb facs="#facs_2_r8l3" n="N003"/>Hellenen, Römer,
				<lb facs="#facs_2_r8l4" n="N004"/>Byzantiner und westliche
				<lb facs="#facs_2_r8l5" n="N005"/>Kirche - Gothisch modern.
			</p>
			<p facs="#facs_2_r9" xml:id="p.zhAluD" prev="#p.bQhxff" next="#p.2dCPFr">
				<lb facs="#facs_2_r9l1" n="N001"/>Einiges über neue Teppichfabrikation.
				<lb facs="#facs_2_r9l2" n="N002"/><del rend="durchstr">und mangelhaf</del> Auch hier Mangel an <subst><del rend="überschr">e</del><add>E</add></subst>igenthümlich<subst><del rend="überschr">er</del><add>keit</add></subst>
				<lb facs="#facs_2_r9l3" n="N003"/><del rend="durchstr">An</del> und Entschiedenheit. <handShift script="Latein"/>Gobelins, Beauvais,<handShift script="Kurrent"/>
				<lb facs="#facs_2_r9l4" n="N004"/><subst><del rend="überschr"><unclear extent="1 Graph" unit="char" quantity="1"></unclear></del><add>E</add></subst>nglische Fabrikation. Pariser Ausstellung.
				<lb facs="#facs_2_r9l5" n="N005"/>Einige stylistische Rathschläge und wie wir aus
				<lb facs="#facs_2_r9l6" n="N006"/>der von den Chinesen so sehr ausgebildeten
				<lb facs="#facs_2_r9l7" n="N007"/><subst><del rend="überschr">S</del><add>E</add></subst>crans <unclear><del rend="durchstr">s</del></unclear>spanische Wände zu bedienen
				<lb facs="#facs_2_r9l8" n="N008"/>haben.
			</p>
			<pb facs="#facs_2" n="2" xml:id="F20_Ms_184_2r"/>
			<p facs="#facs_2_r10" xml:id="p.DzyRlI">
				<lb facs="#facs_2_r10l1" n="N001"/><handShift new="#hWH"/><hi rend="Kreis">3</hi><handShift new="#hGS"/>
			</p>
			<p facs="#facs_2_r11" xml:id="p.2dCPFr" prev="#p.zhAluD" next="#p.PEdeLp">
				<lb facs="#facs_2_r11l1" n="N001"/>Einige Details über
				<lb facs="#facs_2_r11l2" n="N002"/>besondere <del rend="durchstr">Arten</del>
				<lb facs="#facs_2_r11l3" n="N003"/><retrace>Zw</retrace>eige <del rend="durchstr">textiler</del> von
				<lb facs="#facs_2_r11l4" n="N004"/>Lu<subst><del rend="überschr">s</del><add>x</add></subst>usweberei und
				<lb facs="#facs_2_r11l5" n="N005"/>Stickerei.
			</p>
			<p facs="#facs_2_r12" xml:id="p.PEdeLp" prev="#p.2dCPFr" next="#p.8Vj2GI">
				<lb facs="#facs_2_r12l1" n="N001"/>c) <hi rend="unterstr">Die keramischen Producte</hi>
				<lb facs="#facs_2_r12l2" n="N002"/>Die ältesten Zeugen der Cultur und die wenigstens
				<lb facs="#facs_2_r12l3" n="N003"/><del rend="durchstr">in s</del> in dieser Beziehung der Ancienit<sic>a</sic>t
				<lb facs="#facs_2_r12l4" n="N004"/>nach im Vorrecht. <del rend="durchstr">Geschichte der Keramik</del>
				<lb facs="#facs_2_r12l5" n="N005"/>Was zur Keramik im weitesten
				<lb facs="#facs_2_r12l6" n="N006"/>Sinne gehört.
			</p>
			<p facs="#facs_2_r13" xml:id="p.8Vj2GI" prev="#p.PEdeLp" next="#p.QSOBAo">
				<lb facs="#facs_2_r13l1" n="N001"/>Woher de Name.
				<lb facs="#facs_2_r13l2" n="N002"/><delSpan spanTo="#A20_Ms_184_2_1" rend="durchstr Blei"/>Hier ist wie im Vorhergehenden Folgende<del rend="durchstr">s</del>
				<lb facs="#facs_2_r13l3" n="N003"/>Reihenfolge streng zu beobachten
				<lb facs="#facs_2_r13l4" n="N004"/><handShift script="Latein"/>a)<handShift script="Kurrent"/> <del rend="durchstr">materielle</del> das wissenschaftliche
				<lb facs="#facs_2_r13l5" n="N005"/><handShift script="Latein"/>b)<handShift script="Kurrent"/> d<subst><del rend="durchstr">as</del><add>ie</add></subst> aesthetische<add place="in_Zeile"></add>n <unclear>Fragen</unclear>.
				<lb facs="#facs_2_r13l6" n="N006"/><handShift script="Latein"/>c)<handShift script="Kurrent"/> die Kunstgeschichte. und die Kunstlehre<anchor xml:id="A20_Ms_184_2_1"/>
				<lb facs="#facs_2_r13l7" n="N007"/><del rend="durchstr"><handShift script="Latein"/>a)<handShift script="Kurrent"/> das die Gesetze der Symmetrie</del>
			</p>
			<p facs="#facs_2_r14" xml:id="p.QSOBAo" prev="#p.8Vj2GI" next="20_MS_184_3.xml#p.U6EvpE">
				<lb facs="#facs_2_r14l1" n="N001"/>Die ästhetischen Gesetze <del rend="durchstr">der Vor<unclear>g</unclear>e</del> zuerst an
				<lb facs="#facs_2_r14l2" n="N002"/>der Töpferei zur Anwendung gebracht und
				<lb facs="#facs_2_r14l3" n="N003"/>wahrscheinlich bereits geregelt. -
				<lb facs="#facs_2_r14l4" n="N004"/>Jede<add place="in_Zeile">s</add> <del rend="durchstr">Ziervase</del> Gefäss hat seine reelle
				<lb facs="#facs_2_r14l5" n="N005"/>oder gedachte Bestimmung und ihr
				<lb facs="#facs_2_r14l6" n="N006"/>gemäss eine Art von Ideal dem sie in
				<lb facs="#facs_2_r14l7" n="N007"/>ihrem Erscheinen entsprechen muss. Diese Grund<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_2_r14l8" n="N008" type="hyph"/><del rend="durchstr">form muss mehr</del> bestimmung<unclear>en</unclear> und daraus hervor-
				<lb facs="#facs_2_r14l9" n="N009" type="hyph"/>gehende <add place="oberhalb">ideale</add> Grundform muss man kennen und
				<lb facs="#facs_2_r14l10" n="N010"/>sie dann durch die Materie verkörpern wissen<unclear>.</unclear>
				<lb facs="#facs_2_r14l11" n="N011"/>Daher <unclear>erstens</unclear> die verschiedenen <del rend="durchstr">Vasen</del><add place="oberhalb">Formen</add> nach
				<lb facs="#facs_2_r14l12" n="N012"/>ihrer Bestimmung<unclear>en</unclear>
				<lb facs="#facs_2_r14l13" n="N013"/><handShift script="Latein"/>a<handShift script="Kurrent"/>) einfache
				<lb facs="#facs_2_r14l14" n="N014"/><handShift script="Latein"/>b<handShift script="Kurrent"/>) zusammengesetzte.
			</p>
			<join target="#p.QSOBAo 20_MS_184_3.xml#p.U6EvpE"/>
