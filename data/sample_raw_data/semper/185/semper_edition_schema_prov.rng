   <define name="tei_se_provatt.ascribed.attributes">
      <ref name="tei_se_provatt.ascribed.attribute.who"/>
   </define>
   <define name="tei_se_provatt.ascribed.attribute.who">
      <optional>
         <attribute name="who">
            <a:documentation xmlns:a="http://relaxng.org/ns/compatibility/annotations/1.0">indicates the person, or group of people, to whom the element content is ascribed.</a:documentation>
