         <ref name="tei_se_provmodel.pPart.msdesc"/>
         <ref name="tei_se_provmodel.pPart.editorial"/>
         <ref name="tei_se_provmodel.ptrLike"/>
         <ref name="tei_se_provmodel.phrase.xml"/>
         <ref name="tei_se_provmodel.pPart.data"/>
      </choice>
   </define>
   <define name="tei_se_provmodel.divLike">
