   <define name="tei_se_provmodel.div1Like">
      <choice>
         <ref name="tei_se_provdiv1"/>
      </choice>
   </define>
   <define name="tei_se_provmodel.div2Like">
      <choice>
         <ref name="tei_se_provdiv2"/>
      </choice>
   </define>
   <define name="tei_se_provmodel.div3Like">
