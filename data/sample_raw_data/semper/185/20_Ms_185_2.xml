			<pb facs="#facs_2" n="2" xml:id="F20_Ms_185_1v"/>
			<p facs="#facs_2_r1" xml:id="p.gkI3nz"><handShift new="#hGS" script="Kurrent" medium="STinte"/>
				<lb facs="#facs_2_r1l1" n="N001"/><handShift new="#hWH" medium="Blei" script="Latein"/><hi rend="Kreis">2</hi>
			</p>
			<p facs="#facs_2_r2" xml:id="p.9hsKqi">
				<lb facs="#facs_2_r2l1" n="N001"/><handShift new="#hGS" medium="STinte" script="Kurrent"/>00<unclear>.</unclear>
			</p>
			<p facs="#facs_2_r3" xml:id="p.cbcqvo">
				<lb facs="#facs_2_r3l1" n="N001"/><handShift new="#hMF" medium="Blei"/>(163) 3
			</p>
			<p facs="#facs_2_r4" xml:id="p.46eCQD" prev="20_Ms_185_1.xml#p.OY1oGr" next="#p.tbWFXE">
				<lb facs="#facs_2_r4l1" n="N001"/><handShift new="#hGS" medium="STinte" script="Kurrent"/><rs type="people" ref="voelkerregister.xml#PEOPLE0016">Kelten</rs>, <rs type="people" ref="voelkerregister.xml#PEOPLE0048">Gallier</rs>, <hi rend="unterstr"><rs type="people" ref="voelkerregister.xml#PEOPLE0003">Deutsche</rs></hi> <rs type="people" ref="voelkerregister.xml#PEOPLE0014">Finnen</rs> <rs type="people" ref="voelkerregister.xml#PEOPLE0018">Slaven</rs>.
				<lb facs="#facs_2_r4l2" n="N002"/><rs type="people" ref="voelkerregister.xml#PEOPLE0019">Scandinavier</rs> alle haben architectonisch
				<lb facs="#facs_2_r4l3" n="N003"/>Reminiscenzen mit sich in den
				<lb facs="#facs_2_r4l4" n="N004"/>Myten hinüber getragen.
				<lb facs="#facs_2_r4l5" n="N005"/>Einzelne Belege dazu <unclear>-</unclear> <rs type="artefact" ref="artefaktenregister.xml#THING0222">Stonehenge</rs>
				<lb facs="#facs_2_r4l6" n="N006"/>Die Tempel der <rs type="people" ref="voelkerregister.xml#PEOPLE0018">Slaven</rs> (<rs type="person" ref="personen.xml#CFR">Rumohr</rs>)
				<lb facs="#facs_2_r4l7" n="N007"/>d<unclear>ie</unclear> Tempel in <rs type="place" ref="ortsregister.xml#UPSALA1">Upsala</rs> dergl.
				<lb facs="#facs_2_r4l8" n="N008"/><handShift script="Latein"/><rs type="person" ref="personen.xml#SG">Saxo Grammaticus</rs><handShift script="Kurrent"/>.
				<lb facs="#facs_2_r4l9" n="N009"/>Die alt normannische Kirche des
				<lb facs="#facs_2_r4l10" n="N010"/>Schl<unclear>enge</unclear>flecht deren. <add place="oberhalb" rend="STinte" xml:id="add.HH1i8Q"><unclear reason="capitalized or not">Z</unclear>u</add> <rs type="person" ref="personen.xml#KdG">Karl der
				<lb facs="#facs_2_r4l11" n="N011"/>Grossen</rs> Zeit <unclear>von</unclear> Einfluss <unclear>auf</unclear> die
				<lb facs="#facs_2_r4l12" n="N012"/>Kunst.
				<lb facs="#facs_2_r4l13" n="N013"/>Vor allem die atriale Verbind<sic>g</sic>
				<lb facs="#facs_2_r4l14" n="N014"/>des Hofes mit der Hölle.
				<lb facs="#facs_2_r4l15" n="N015"/>(<rs type="person" ref="personen.xml#KWH">Weinhold</rs>) älteste Burgen
				<lb facs="#facs_2_r4l16" n="N016"/>und Gehöft<unclear>e</unclear> aus <rs type="person" ref="personen.xml#KdG">K. d. G.</rs> Zeit.
				<lb facs="#facs_2_r4l17" n="N017"/>(<rs type="artefact" ref="artefaktenregister.xml#THING0226">Kloster v. St. Gallen</rs>. -- .
			</p>
			<p facs="#facs_2_r5" xml:id="p.tbWFXE" prev="#p.46eCQD" next="#p.f97zuY">
				<lb facs="#facs_2_r5l1" n="N001"/><del rend="durchstr STinte" xml:id="del.OTgnxg">Wenn s<unclear>chon</unclear> diese</del>
				<lb facs="#facs_2_r5l2" n="N002"/><del rend="durchstr STinte" xml:id="del.Qj9ylM">Die Formen und Symbole</del>
				<lb facs="#facs_2_r5l3" n="N003"/>So verschieden sich <del rend="durchstr STinte" xml:id="del.MJq73n">dies<unclear>e</unclear></del> <del rend="durchstr STinte" xml:id="del.In3MXK">al</del> in diesen
				<lb facs="#facs_2_r5l4" n="N004"/><del rend="durchstr STinte" xml:id="del.NBz1I4">ältesten</del> Uebberresten und Traditionen
				<lb facs="#facs_2_r5l5" n="N005"/>der ältesten Kunst als Ausdrucks-
				<lb facs="#facs_2_r5l6" n="N006" type="hyph"/>bestehende oder versch<unclear>ollene</unclear> gesellschaftliche
				<lb facs="#facs_2_r5l7" n="N007"/>Zustände <del rend="durchstr STinte" xml:id="del.8JFfS9"><unclear>gest</unclear></del> <del rend="durchstr STinte" xml:id="del.T6d3m5">charakterisir<unclear>en</unclear> so hab</del> <add place="oberhalb" xml:id="add.cV0BCa">diese letzteren sich</add>
				<lb facs="#facs_2_r5l8" n="N008"/><del rend="durchstr STinte" xml:id="del.ej4c61">sie</del> symbolisch in ihm <unclear>erscheint</unclear>
				<lb facs="#facs_2_r5l9" n="N009"/><del rend="durchstr STinte" xml:id="del.QCUwSu">so erkennt man dennoch eine</del>
				<lb facs="#facs_2_r5l10" n="N010"/>so <del rend="durchstr STinte" xml:id="del.SkiZpb">verbinden</del> <add place="oberhalb" xml:id="add.aS8SGo">haben</add> sie <del rend="durchstr STinte" xml:id="del.IIfio1">sich</del> dennoch <del rend="durchstr STinte" xml:id="del.9IDYxG"><unclear>daraus</unclear></del> <add place="nach_Zeile" xml:id="add.tv8b55">zugleich grosse <del rend="durchstr STinte" xml:id="del.pHcXIs">Annaherug</del> Affinität</add> <add place="unterhalb">zu <unclear>einander</unclear></add>
				<lb facs="#facs_2_r5l11" n="N011"/>und gaben sich <add place="oberhalb" xml:id="add.UNsiYM">in</add> gewisser Hinsicht als 
				<lb facs="#facs_2_r5l12" n="N012"/>aus einem Urkeime stammend
				<lb facs="#facs_2_r5l13" n="N013"/><del rend="durchstr STinte" xml:id="del.qrlTHE">und dadurch kund, dass</del> oder vielmehr
				<lb facs="#facs_2_r5l14" n="N014"/>als Konglomerate kund, deren
				<lb facs="#facs_2_r5l15" n="N015"/>Urbestandtheile wiederum sich als
				<lb facs="#facs_2_r5l16" n="N016"/>Bruchstücke früherer <del rend="durchstr STinte" xml:id="del.bC2jsT">Kunstform</del>
				<lb facs="#facs_2_r5l17" n="N017"/><del rend="durchstr STinte" xml:id="del.s2Gc1q">g<unclear extent="2 Graphen" unit="char" quantity="2"/></del> Kunstformen darthun, die ihrerseits
				<lb facs="#facs_2_r5l18" n="N018"/>die Ausdrucke <del rend="durchstr STinte" xml:id="del.CARgNA">alterer</del> <sic>alterer</sic> <add place="nach_Zeile">und <add place="in_Zeile">ge</add><unclear extent="5 Graphen" unit="char" quantity="5"/><unclear>iver</unclear></add>
				<lb facs="#facs_2_r5l19" n="N019"/>Kulturzust<sic>a</sic>nde <del rend="durchstr STinte" xml:id="del.afOHHm">stande</del> waren.
				<lb facs="#facs_2_r5l20" n="N020"/>Sie haben sich in ihnen theils stofflich
				<lb facs="#facs_2_r5l21" n="N021"/>theils nur noch symbolisch erhalten
				<lb facs="#facs_2_r5l22" n="N022"/><del rend="durchstr STinte" xml:id="del.RNeCU6">und</del> Sie lassen sich <unclear>damit</unclear> erkennen <add place="nach_Zeile">so</add>
				<lb facs="#facs_2_r5l23" n="N023"/><unclear>und</unclear> untersche<unclear>iden</unclear>.
			</p>
			<p facs="#facs_2_r6" xml:id="p.f97zuY" prev="#p.tbWFXE" next="#p.cHVxS4">
				<lb facs="#facs_2_r6l1" n="N001"/>2º lassen sie sich aus der Analogie
				<lb facs="#facs_2_r6l2" n="N002"/>erkennen, wie sich <del rend="durchstr STinte" xml:id="del.hijrjg">bei</del> spätern
				<lb facs="#facs_2_r6l3" n="N003"/>Kunstformationen <del rend="durchstr STinte" xml:id="del.GMrvrY">gan</del> aus
				<lb facs="#facs_2_r6l4" n="N004"/>ganz <sic>a</sic>hnlich oder vielmehr
			</p>
			<pb facs="#facs_2" n="2" xml:id="F20_Ms_185_2r"/>
			<p facs="#facs_2_r7" xml:id="p.zAokpW">
				<lb facs="#facs_2_r7l1" n="N001"/><handShift new="#hWH" medium="Blei" script="Latein"/><hi rend="Kreis">3</hi>
			</p>
			<p facs="#facs_2_r8" xml:id="p.lmmNJ5">
				<lb facs="#facs_2_r8l1" n="N001"/><handShift new="#hGS" medium="STinte" script="Kurrent"/>0.
			</p>
			<p facs="#facs_2_r9" xml:id="p.DXEHHL">
				<lb facs="#facs_2_r9l1" n="N001"/><handShift new="#hMF" medium="Blei"/>(163) 3-2
			</p>
			<p facs="#facs_2_r10" xml:id="p.cHVxS4" prev="#p.f97zuY" next="#p.jwN3lM">
				<lb facs="#facs_2_r10l1" n="N001"/><handShift new="#hGS" medium="STinte" script="Kurrent"/>denselben Elementen heraus
				<lb facs="#facs_2_r10l2" n="N002"/>bilden. Judentempel.
				<lb facs="#facs_2_r10l3" n="N003"/>Byzantinisch-Christl. <sic>u</sic>berhaupt
				<lb facs="#facs_2_r10l4" n="N004"/>Christlicher Tempelstil.
			</p>
			<p facs="#facs_2_r11" xml:id="p.jwN3lM" prev="#p.cHVxS4" next="#p.bBiNBA">
				<lb facs="#facs_2_r11l1" n="N001"/>Diese ur<sic>a</sic>ltesten Symbole <del rend="durchstr STinte" xml:id="del.KpFyIU">der</del>
				<lb facs="#facs_2_r11l2" n="N002"/><add place="vor_Zeile" xml:id="add.Nrcelj">und Typen der</add> <rs type="term" ref="begriffsregister.xml#TERM0004">Baukunst</rs>, gleichsam ihre Elemente
				<lb facs="#facs_2_r11l3" n="N003"/>sind nicht <hi rend="unterstr STinte">räumlich<unclear reason="separated or joined"><del rend="durchstr STinte" xml:id="del.ONo02G">er</del></unclear> formell<del rend="durchstr STinte" xml:id="del.eTWUNQ">e</del>,</hi>
				<lb facs="#facs_2_r11l4" n="N004"/><add place="vor_Zeile" xml:id="add.xvXK5h">wie jene sekundären,</add> sondern <hi rend="unterstr STinte">konstructiv</hi>. <del rend="durchstr STinte" xml:id="del.rijQx7">Sie reichen</del>
			</p>
			<p facs="#facs_2_r12" xml:id="p.bBiNBA" prev="#p.jwN3lM" next="#p.y3Pbzr">
				<lb facs="#facs_2_r12l1" n="N001"/><add place="vor_Zeile" xml:id="add.prhp9Q"><hi rend="unterstr">H<unclear>ee</unclear>rd</hi>.</add> <del rend="durchstr STinte" xml:id="del.Zz9lOt">Sie bestehen in der</del> Sie rühren
				<lb facs="#facs_2_r12l2" n="N002"/>aus einer Zeit wie es noch keine
				<lb facs="#facs_2_r12l3" n="N003"/><add place="vor_Zeile" xml:id="add.5goOm5">eigentliche</add> <rs type="term" ref="begriffsregister.xml#TERM0004">Baukunst</rs> <del rend="durchstr STinte" xml:id="del.5fbDCA">als solche</del> gab. <del rend="durchstr STinte" xml:id="del.VPMCM3">Die aber erst</del>
				<lb facs="#facs_2_r12l4" n="N004"/><del rend="durchstr STinte" xml:id="del.k1SyYM"><add place="vor_Zeile" xml:id="add.r1byNc">mit der Gesellschaft</add> entstanden ist</del> und dem Ursprunge
				<lb facs="#facs_2_r12l5" n="N005"/>der Gesellschaft nahe liegt. Die <rs type="term" ref="begriffsregister.xml#TERM0004">Bau-
				<lb facs="#facs_2_r12l6" n="N006" type="hyph"/>kunst</rs> besteht in einem Zusamm<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_2_r12l7" n="N007" type="hyph"/>enwirken aller Künste zu einem
				<lb facs="#facs_2_r12l8" n="N008"/>gemeinsamen Ausdrucke der
				<lb facs="#facs_2_r12l9" n="N009"/>Gesellschaft zu einer <sic>a</sic>usseren
				<lb facs="#facs_2_r12l10" n="N010"/><add place="vor_Zeile" xml:id="add.5pHzfT">Kunst-</add>Form derselben. Die Gesell-
				<lb facs="#facs_2_r12l11" n="N011" type="hyph"/>schaft musste sich vorher <add place="oberhalb" xml:id="add.AecLAD">selbst</add> künstlerisch
				<lb facs="#facs_2_r12l12" n="N012"/><add place="vor_Zeile" xml:id="add.zcvPE9"><unclear reason="capitalized or not">Z</unclear>ur Form</add> ausgebildet haben ehe die <rs type="term" ref="begriffsregister.xml#TERM0004">Baukunst</rs>
				<lb facs="#facs_2_r12l13" n="N013"/>entstehen <sic>konnt</sic> - Aber d<sic>ie</sic>
				<lb facs="#facs_2_r12l14" n="N014"/>Kunstsinn hatte schon Uebung
				<lb facs="#facs_2_r12l15" n="N015"/>g<unclear>ew</unclear>onnen und sich auszudrücken
				<lb facs="#facs_2_r12l16" n="N016"/>Gelegenheit gehabt vor diese<unclear>r</unclear>
				<lb facs="#facs_2_r12l17" n="N017"/>k<sic>u</sic>nstlichen Gestaltung der Gesellschaft
				<lb facs="#facs_2_r12l18" n="N018"/>und noch in ihrem <add place="oberhalb" xml:id="add.2yZ9tN">mehr</add> freie<unclear>m</unclear> Urzu<choice><sic/><corr>-</corr></choice>
				<lb facs="#facs_2_r12l19" n="N019" type="hyph"/>stande. So war die <rs type="term" ref="begriffsregister.xml#TERM0004">Baukunst</rs>
				<lb facs="#facs_2_r12l20" n="N020"/>die jüngste der Künste. Die
				<lb facs="#facs_2_r12l21" n="N021"/><unclear>ä</unclear>ltes<sic>t</sic> Gesellschaftsform ist die Familie
				<lb facs="#facs_2_r12l22" n="N022"/><hi rend="unterstr">der Heerd.</hi> Der Sch<unclear>u</unclear>tz des
				<lb facs="#facs_2_r12l23" n="N023"/>Heerdes bedürfte des Zusammen<unclear>-</unclear>
				<lb facs="#facs_2_r12l24" n="N024" type="hyph"/>wirkens der verschiedenen
				<lb facs="#facs_2_r12l25" n="N025"/><rs type="term" ref="begriffsregister.xml#TERM0023">technischen Künste</rs>, sie <unclear>würde</unclear>
